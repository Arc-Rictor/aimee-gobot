# Vinted UK connector — all optional, sensible defaults if unset.
# Copy to .env and edit only what you need.

# Where the logged-in Vinted browser session is stored.
# VINTED_PROFILE_DIR=~/.gobot/vinted-profile

# Show the browser window while drafting/publishing (1 = visible).
# Handy for solving the occasional captcha.
# VINTED_HEADED=0

# Extra logging + screenshots while debugging selectors.
# VINTED_DEBUG=0

# Where review screenshots are written.
# VINTED_SHOT_DIR=./.vinted-shots

# Base pause (ms) between items in bulk runs (jittered up to +50%).
# VINTED_BULK_DELAY_MS=20000

# The Vinted site to drive (defaults to UK).
# VINTED_BASE_URL=https://www.vinted.co.uk

# Override the Chromium binary if auto-detection fails.
# VINTED_CHROMIUM_PATH=
