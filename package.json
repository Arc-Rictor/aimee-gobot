{
  "name": "vinted-uk-lister",
  "version": "1.0.0",
  "description": "Automate listing items for sale on vinted.co.uk — you supply photos, Claude writes the listing and the connector drafts/publishes it via a real browser. MCP server + batch CLI.",
  "type": "module",
  "scripts": {
    "vinted:setup": "bun run setup/vinted-setup.ts",
    "vinted:list": "tsx scripts/vinted-list.ts",
    "vinted:upload": "bun run scripts/vinted-upload-server.ts",
    "vinted:mcp": "tsx mcp-servers/vinted/server.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "playwright": "^1.61.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "tsx": "^4.22.4",
    "typescript": "^5.7.0"
  },
  "engines": {
    "bun": ">=1.0.0",
    "node": ">=18.0.0"
  },
  "license": "MIT"
}
