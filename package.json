{
  "name": "gobot",
  "version": "2.11.0",
  "description": "Always-on AI Telegram agent powered by Claude with multi-agent routing, proactive check-ins, and persistent memory",
  "type": "module",
  "scripts": {
    "start": "bun run src/bot.ts",
    "chat": "bun run src/cli-chat.ts",
    "discord": "bun run src/discord-bot.ts",
    "vps": "bun run src/vps-gateway.ts",
    "checkin": "bun run src/smart-checkin.ts",
    "briefing": "bun run src/morning-briefing.ts",
    "watchdog": "bun run src/watchdog.ts",
    "heartbeat:discord": "bun run src/discord-heartbeat.ts",
    "briefing:discord": "bun run src/discord-briefing.ts",
    "overnight": "bun run src/discord-overnight.ts",
    "reflection:discord": "bun run src/discord-reflection.ts",
    "digest": "bun run src/discord-weekly-digest.ts",
    "setup": "bun run setup/install.ts",
    "setup:launchd": "bun run setup/configure-launchd.ts",
    "setup:services": "bun run setup/configure-services.ts",
    "setup:verify": "bun run setup/verify.ts",
    "setup:google": "bun run setup/setup-google-oauth.ts",
    "test:telegram": "bun run setup/test-telegram.ts",
    "test:supabase": "bun run setup/test-supabase.ts",
    "test:convex": "bun run setup/test-convex.ts",
    "setup:convex": "bun run setup/configure-convex.ts",
    "migrate:convex": "bun run scripts/migrate-to-convex.ts",
    "uninstall": "bun run setup/uninstall.ts",
    "upgrade": "bun run setup/upgrade.ts",
    "feedback": "bun run src/feedback.ts"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.1.54",
    "@anthropic-ai/sdk": "^0.39.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@supabase/supabase-js": "^2.49.0",
    "agentmail": "^0.4.3",
    "convex": "^1.32.0",
    "discord.js": "^14.25.1",
    "grammy": "^1.35.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.7.0"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "license": "MIT"
}
